# NEXUS — Environment Variables
# Copy this file to .env and fill in your values.

# Paperclip local API endpoint (default: http://127.0.0.1:3100)
REACT_APP_PAPERCLIP_API_URL=http://127.0.0.1:3100

# Your Paperclip company ID — required for live agent data and agent actions
REACT_APP_PAPERCLIP_COMPANY_ID=your-company-id-here

# Optional: Paperclip API key for write operations (Redirect action)
# Leave empty for read-only mode — Inspect and Review will still work
REACT_APP_PAPERCLIP_API_KEY=
