# NEXUS — Environment Variables
# Copy to .env and fill in your values.
# For Vercel deployment, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# ── Paperclip (Operational Intelligence) ─────────────────────────────────────
REACT_APP_PAPERCLIP_API_URL=http://127.0.0.1:3100
REACT_APP_PAPERCLIP_COMPANY_ID=your-company-id-here
REACT_APP_PAPERCLIP_API_KEY=

# ── Supabase (Auth + Database) ────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only (Vercel functions + webhook)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe (Subscriptions) ────────────────────────────────────────────────────
# Get from: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...         # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...       # from Stripe webhook endpoint settings
STRIPE_PERSONAL_PRICE_ID=price_...    # Personal plan recurring price ID
STRIPE_TEAM_PRICE_ID=price_...        # Team plan recurring price ID

# Frontend (publishable key — safe to expose)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...
REACT_APP_STRIPE_PERSONAL_PRICE_ID=price_...
REACT_APP_STRIPE_TEAM_PRICE_ID=price_...

# ── Anthropic (AI Features) ───────────────────────────────────────────────────
# Server-side only — never expose to frontend
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── App URL (for Stripe redirects) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Local development only ────────────────────────────────────────────────────
# Port for local Express server (used only in dev; Vercel functions replace this in prod)
AI_SERVER_PORT=3001
